# === Header / titles ===

msgid "DSP"
msgstr "DSP"

msgid "System-wide audio enhancement — set output to BigSound (DSP) in Sound settings."
msgstr "Realce de áudio do sistema todo — selecione BigSound (DSP) em Configurações de Som."

msgid "Output device"
msgstr "Dispositivo de saída"

msgid "Pick \"BigSound (DSP)\" in Settings → Sound → Output to route audio through BigSound."
msgstr "Selecione \"BigSound (DSP)\" em Configurações → Som → Saída para enviar o áudio pelo BigSound."

# === Slider titles ===

msgid "Bass"
msgstr "Grave"

msgid "Bass Frequency (Hz)"
msgstr "Frequência do Grave (Hz)"

msgid "Bass Mix"
msgstr "Mix do Grave"

msgid "Clarity"
msgstr "Brilho"

msgid "Space"
msgstr "Espaço"

msgid "Crossfeed (Headphones)"
msgstr "Crossfeed (Fones)"

msgid "Loudness"
msgstr "Loudness"

msgid "Output Ceiling (dB)"
msgstr "Teto de Saída (dB)"

# === Slider subtitles ===

msgid "Make-up gain on the psychoacoustic bass enhancement"
msgstr "Ganho de compensação no realce psicoacústico de grave"

msgid "Below this the speaker rolls off; harmonics are synthesised here"
msgstr "Abaixo dessa frequência o alto-falante perde resposta; os harmônicos são sintetizados aqui"

msgid "How much of the synthesised harmonic content to add"
msgstr "Quanto do conteúdo harmônico sintetizado misturar"

msgid "Treble exciter — sparkle on hi-hats, vocals, strings"
msgstr "Exciter de agudos — brilho em pratos, voz e cordas"

msgid "Stereo widening — 1.0 neutral, >1.0 wider, with bass kept centred"
msgstr "Alargamento estéreo — 1,0 neutro, >1,0 mais amplo, com grave mantido no centro"

msgid "Out-of-head soundstage — moves the image forward, less fatigue. 0 on speakers."
msgstr "Palco sonoro fora da cabeça — projeta a imagem à frente, menos cansaço. 0 em alto-falantes."

msgid "Compressor strength — higher = louder average, less dynamic"
msgstr "Intensidade do compressor — maior = média mais alta, menos dinâmica"

msgid "Peak limiter target — closer to 0 = louder peaks, more risk"
msgstr "Alvo do limiter de pico — perto de 0 = picos mais altos, mais risco"

