{
  "name": "Bluetooth",
  "description": "Limited-bandwidth tuning for BT speakers/headphones. Light crossfeed assumes BT headphones.",
  "match_patterns": [
    "bluez_output\\..*",
    "bluez_sink\\..*"
  ],
  "params": {
    "bigbass:target_freq":  100.0,
    "bigbass:drive":          0.45,
    "bigbass:mix":            0.4,
    "bigbass:cut_dry_lows":   0.0,
    "bigbass:loudness_db":    3.5,
    "bigclarity:target_freq": 3000.0,
    "bigclarity:drive":       0.35,
    "bigclarity:mix":         0.2,
    "bigspace:width":         1.15,
    "bigspace:bass_keep_hz": 150.0,
    "bigspace:mix":           1.0,
    "bigcross:amount":        0.4,
    "bigcross:cutoff_hz":   700.0,
    "bigcross:delay_us":    280.0,
    "bigloud:amount":         0.65,
    "bigloud:ceiling_db":    -1.5,
    "bigloud:mix":            1.0
  }
}
